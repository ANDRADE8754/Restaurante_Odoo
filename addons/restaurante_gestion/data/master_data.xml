<odoo>
    <data noupdate="1">
        
        <!-- 2. Diez Clientes de Prueba (10 registros requeridos) -->
        <record id="cliente_1" model="res.partner"><field name="name">Consumidor Final</field><field name="city">Patate</field></record>
        <record id="cliente_2" model="res.partner"><field name="name">Carlos Ramos</field><field name="city">Quito</field></record>
        <record id="cliente_3" model="res.partner"><field name="name">Christian Hurtado</field><field name="city">Ambato</field></record>
        <record id="cliente_4" model="res.partner"><field name="name">Kleber Vega</field><field name="city">Lago Agrio</field></record>
        <record id="cliente_5" model="res.partner"><field name="name">Empresa XYZ S.A.</field><field name="city">Ambato</field><field name="is_company">True</field></record>
        <record id="cliente_6" model="res.partner"><field name="name">Maria Fernanda Silva</field><field name="city">Baños</field></record>
        <record id="cliente_7" model="res.partner"><field name="name">Roberto Gómez</field><field name="city">Pelileo</field></record>
        <record id="cliente_8" model="res.partner"><field name="name">Ana Lucia Paz</field><field name="city">Ambato</field></record>
        <record id="cliente_9" model="res.partner"><field name="name">Jorge Luis Pinto</field><field name="city">Quito</field></record>
        <record id="cliente_10" model="res.partner"><field name="name">Distribuidora Andina</field><field name="city">Ambato</field><field name="is_company">True</field></record>

        <!-- Método de pago: Efectivo -->
        <record id="payment_method_cash" model="pos.payment.method">
            <field name="name">Efectivo</field>
            <field name="is_cash_count">True</field>
            <field name="journal_id" search="[('type','=','cash'),('company_id','=',1)]" model="account.journal"/>
        </record>

        <!-- Configuración del POS -->
        <record id="pos_config_restaurante" model="pos.config">
            <field name="name">La Comanda</field>
            <field name="payment_method_ids" eval="[(4, ref('payment_method_cash'))]"/>
        </record>

        <!-- 3. Productos Base para el Menú y Sitio Web -->
        <record id="prod_llapingacho" model="product.template">
            <field name="name">Llapingachos Tradicionales</field>
            <field name="list_price">5.50</field>
            <field name="type">consu</field>
            <field name="available_in_pos">True</field>
        </record>
        <record id="prod_ceviche" model="product.template">
            <field name="name">Ceviche de Camarón</field>
            <field name="list_price">8.00</field>
            <field name="type">consu</field>
            <field name="available_in_pos">True</field>
        </record>

    </data>
</odoo>